rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'sayedozair25@gmail.com' && request.auth.token.email_verified == true) ||
        (request.auth.token.email == 'admin@rally.com')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role']) &&
             data.keys().size() == 3 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 5 &&
             data.role in ['customer', 'admin'];
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'category', 'price', 'description', 'image']) &&
             data.keys().size() >= 5 && data.keys().size() <= 6 &&
             data.name is string && data.name.size() > 0 &&
             data.category is string &&
             data.price is number && data.price >= 0 &&
             data.description is string &&
             data.image is string;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'totalPrice', 'status', 'deliveryType', 'address', 'pinCode', 'userName', 'userPhone', 'createdAt']) &&
             data.keys().size() >= 10 && data.keys().size() <= 11 &&
             data.userId == (request.auth != null ? request.auth.uid : 'anonymous') &&
             data.items is list && data.items.size() > 0 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status in ['pending', 'accepted', 'preparing', 'delivered', 'cancelled'] &&
             data.deliveryType in ['delivery', 'pickup'] &&
             data.createdAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userName', 'rating', 'comment', 'createdAt']) &&
             data.keys().size() >= 4 && data.keys().size() <= 5 &&
             data.userName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 500 &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isValidId(userId) && (isOwner(userId) || isAdmin()) && 
                    (isAdmin() || (incoming().name is string && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone'])));
    }

    match /menu_items/{itemId} {
      allow get: if isValidId(itemId);
      allow list: if true;
      allow write: if isAdmin() && isValidMenuItem(incoming());
    }

    match /orders/{orderId} {
      allow get: if isValidId(orderId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid));
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isValidOrder(incoming());
      allow update: if isValidId(orderId) && isAdmin() && (isValidOrder(incoming()) && (incoming().status is string && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])));
    }

    match /delivery_zones/{zoneId} {
      allow get: if isValidId(zoneId);
      allow list: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow get: if isValidId(reviewId);
      allow list: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
